@page "/"
@implements IDisposable

<MudText Typo="Typo.h4" GutterBottom="true">Search</MudText>

@* ── Main search bar (debounced, with filename + content search) ── *@
<MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
    Main search — debounced 300ms, searches filenames then full text
</MudAlert>
<SearchBarItem OnSearchChanged="InputChanged"></SearchBarItem>

<MudDivider Class="my-4" />

<MudText Typo="Typo.h6" GutterBottom="true">Performance Benchmarks</MudText>
<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
    Each bar uses a different search strategy — type the same keyword to compare timings
</MudText>

<MudGrid>
    <MudItem xs="12" sm="4">
        <MudAlert Severity="Severity.Warning" Dense="true">Parallel.ForEachAsync (across files + pages)</MudAlert>
        <SearchBarItem OnSearchChanged="InputChangedFor"></SearchBarItem>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudAlert Severity="Severity.Warning" Dense="true">Task.WhenAll</MudAlert>
        <SearchBarItem OnSearchChanged="InputChangedTaskWhenAll"></SearchBarItem>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudAlert Severity="Severity.Warning" Dense="true">Parallel.ForEachAsync (across files)</MudAlert>
        <SearchBarItem OnSearchChanged="InputChangedParalell"></SearchBarItem>
    </MudItem>
</MudGrid>

<MudDivider Class="my-4" />

@* ── Results section ── *@

@if (loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="mr-2" />
    <MudText Typo="Typo.caption" Inline="true">Searching...</MudText>
}
else if (!string.IsNullOrWhiteSpace(SearchWord) && FileCount == 0)
{
    <MudAlert Severity="Severity.Info" Class="mt-4">
        No results found for <b>@SearchWord</b>. Try a different keyword or upload more PDFs.
    </MudAlert>
}
else if (FileCount > 0)
{
    <p>@FileCount result(s), in @elapsedMs ms</p>

    <MudExpansionPanels Dense="true">
        @foreach (var f in files)
        {
            <MudExpansionPanel Text="@f.FileName">
                <MudGrid>
                    <MudItem xs="12" sm="12" lg="3">
                        <MudCard Style="overflow:auto">
                            <MudCardHeader>
                                @f.FileName
                            </MudCardHeader>
                            <MudCardContent Style="max-height:450px; overflow-y:scroll">
                                @((MarkupString)f.TextToPreview)
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    <MudItem xs="12" sm="12" lg="9">
                        <embed height="750vh" width="100%"
                               type="application/pdf"
                               src="api/file/@(f.Id)" />
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        }
    </MudExpansionPanels>
}

@code { }
